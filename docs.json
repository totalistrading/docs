{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Totalis",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/totalis_logo.png",
  "api": {
    "mdx": {
      "server": "https://api.totalis.trade",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "guides/quickstart",
              "guides/authentication"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "guides/lifecycle",
              "guides/cashout",
              "guides/funding",
              "guides/vault-architecture"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/realtime-and-data",
              "guides/event-catalog",
              "guides/reading-data",
              "guides/webhooks",
              "guides/websocket",
              "guides/live-quote-requests",
              "guides/market-maker"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "guides/faq",
              "guides/world-cup-reward-pool",
              "referrals",
              "terms-of-service",
              "privacy-policy"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Quote service",
            "pages": [
              "api-reference/quote-service/create",
              "api-reference/quote-service/update",
              "api-reference/quote-service/get",
              "api-reference/quote-service/commit",
              "api-reference/quote-service/cancel",
              "api-reference/quote-service/stream",
              "api-reference/quote-service/cashout-create",
              "api-reference/quote-service/cashout-get",
              "api-reference/quote-service/cashout-stream",
              "api-reference/quote-service/cashout-cancel",
              "api-reference/quote-service/cashout-commit"
            ]
          },
          {
            "group": "Market maker",
            "pages": [
              "api-reference/quote-service-mm/stream",
              "api-reference/quote-service-mm/submit-quote",
              "api-reference/quote-service-mm/withdraw-quote",
              "api-reference/quote-service-mm/cashout-quote",
              "api-reference/quote-service-mm/cashout-decline",
              "api-reference/mm/list-quotes",
              "api-reference/mm/confirm-quote",
              "api-reference/mm/list-positions",
              "api-reference/mm/get-position"
