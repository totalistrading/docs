{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Totalis",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/totalis_logo.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "guides/faq",
              "guides/authentication",
              "guides/lifecycle",
              "guides/vault-architecture",
              "guides/websocket"
            ]
          },
          {
            "group": "Vault v2.1 Specification",
            "pages": [
              "guides/vault-api-contract",
              "guides/vault-openapi-reference",
              "guides/vault-backend-schema"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "RFQs",
            "pages": [
              "api-reference/rfqs/create",
              "api-reference/rfqs/list",
              "api-reference/rfqs/get",
              "api-reference/rfqs/cancel",
              "api-reference/rfqs/list-quotes",
              "api-reference/rfqs/accept-quote"
            ]
          },
          {
            "group": "Market Maker",
            "pages": [
              "api-reference/mm/list-rfqs",
              "api-reference/mm/submit-quote",
              "api-reference/mm/list-quotes",
              "api-reference/mm/confirm-quote"
            ]
          },
          {
            "group": "Markets",
            "pages": [
              "api-reference/markets/list",
              "api-reference/markets/exclusion-groups"
            ]
          },
          {
            "group": "User",
            "pages": [
              "api-reference/user/get-profile",
              "api-reference/user/update-username",
              "api-reference/user/check-username",
              "api-reference/user/list-api-keys",
              "api-reference/user/get-wallet",
              "api-reference/user/airdrop-sol",
              "api-reference/user/airdrop-usdc",
              "api-reference/user/get-blockhash",
              "api-reference/user/submit-tx"
            ]
          },
          {
            "group": "Status",
            "pages": [
              "api-reference/status/health",
              "api-reference/status/sync"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/totalis_logo.png",
    "dark": "/totalis_logo.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.totalis.trade"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/totalistrading",
      "github": "https://github.com/totalistrading"
    }
  },
  "openapi": ["/api-reference/openapi.json"],
  "seo": {
    "metatags": {
      "og:type": "website",
      "og:site_name": "Totalis Documentation",
      "og:locale": "en_US",
      "og:image": "https://docs.totalis.trade/totalis.png",
      "twitter:card": "summary_large_image",
      "twitter:image": "https://docs.totalis.trade/totalis.png"
    }
  }
}