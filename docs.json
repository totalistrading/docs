      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/totalis_logo.png",
    "dark": "/totalis_logo.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.totalis.trade"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/totalistrading",
      "github": "https://github.com/totalistrading"
    },
    "links": [
      {
        "header": "Legal",
        "items": [
          {
            "label": "Terms of Service",
            "href": "/terms-of-service"
          },
          {
            "label": "Privacy Policy",
            "href": "/privacy-policy"
          }
        ]
      }
    ]
  },
  "openapi": [
    "/api-reference/openapi.json"
  ],
  "redirects": [
    {
      "source": "/api-reference/mm/submit-quote",
      "destination": "/api-reference/quote-service-mm/submit-quote"
    },
    {
      "source": "/api-reference/mm/withdraw-quote",
      "destination": "/api-reference/quote-service-mm/withdraw-quote"
    },
    {
      "source": "/api-reference/mm/submit-quote-request-quote",
      "destination": "/api-reference/quote-service-mm/submit-quote"
    },
    {
      "source": "/api-reference/mm/withdraw-quote-request-quote",
      "destination": "/api-reference/quote-service-mm/withdraw-quote"
    },
    {
      "source": "/api-reference/mm/list-rfqs",
      "destination": "/api-reference/quote-service-mm/stream"
    },
    {
      "source": "/api-reference/mm/list-quote-requests",
      "destination": "/api-reference/quote-service-mm/stream"
    },
    {
      "source": "/api-reference/rfqs/create",
      "destination": "/api-reference/quote-service/create"
    },
    {
      "source": "/api-reference/rfqs/get",
      "destination": "/api-reference/quote-service/get"
    },
    {
      "source": "/api-reference/rfqs/list",
      "destination": "/guides/reading-data"
    },
    {
      "source": "/api-reference/rfqs/list-quotes",
      "destination": "/api-reference/quote-service/get"
    },
    {
      "source": "/api-reference/rfqs/accept-quote",
      "destination": "/api-reference/quote-service/commit"
    },
    {
      "source": "/api-reference/rfqs/cancel",
      "destination": "/api-reference/quote-service/cancel"
    }
  ],
  "seo": {
    "metatags": {
      "og:type": "website",
      "og:site_name": "Totalis Documentation",
      "og:locale": "en_US",
      "og:image": "https://docs.totalis.trade/totalis.png",
      "twitter:card": "summary_large_image",
      "twitter:image": "https://docs.totalis.trade/totalis.png"
    }
  }
}
