{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Totalis",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/totalis_logo.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "guides/faq",
              "guides/authentication",
              "guides/lifecycle",
              "guides/vault-architecture",
              "guides/websocket",
              "guides/live-quote-requests",
              "guides/market-maker",
              "terms-of-service",
              "privacy-policy"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Quote Service",
            "pages": [
              "api-reference/quote-service/create",
              "api-reference/quote-service/update",
              "api-reference/quote-service/get",
              "api-reference/quote-service/commit",
              "api-reference/quote-service/cancel",
              "api-reference/quote-service/stream"
            ]
          },
          {
            "group": "Market Maker",
            "pages": [
              "api-reference/quote-service-mm/stream",
              "api-reference/quote-service-mm/submit-quote",
              "api-reference/quote-service-mm/withdraw-quote",
              "api-reference/quote-service-mm/heartbeat",
              "api-reference/mm/confirm-quote"
            ]
          },
          {
            "group": "Markets",
            "pages": [
              "api-reference/markets/list",
              "api-reference/markets/exclusion-groups"
            ]
          },
          {
            "group": "User",
            "pages": [
              "api-reference/user/get-profile",
              "api-reference/user/update-username",
              "api-reference/user/check-username",
              "api-reference/user/get-wallet",
              "api-reference/user/get-blockhash",
              "api-reference/user/submit-tx"
            ]
          },
          {
            "group": "API Keys",
            "pages": [
              "api-reference/user/list-api-keys",
              "api-reference/user/create-api-key",
              "api-reference/user/revoke-api-key"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/totalis_logo.png",
    "dark": "/totalis_logo.png"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.totalis.trade"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/totalistrading",
      "github": "https://github.com/totalistrading"
    },
    "links": [
      {
        "header": "Legal",
        "items": [
          {
            "label": "Terms of Service",
            "href": "/terms-of-service"
          },
          {
            "label": "Privacy Policy",
            "href": "/privacy-policy"
          }
        ]
      }
    ]
  },
  "openapi": ["/api-reference/openapi.json"],
  "seo": {
    "metatags": {
      "og:type": "website",
      "og:site_name": "Totalis Documentation",
      "og:locale": "en_US",
      "og:image": "https://docs.totalis.trade/totalis.png",
      "twitter:card": "summary_large_image",
      "twitter:image": "https://docs.totalis.trade/totalis.png"
    }
  }
}
